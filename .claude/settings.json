{
  "permissions": {
    "deny": [
      "Bash(cat .env*)",
      "Bash(cat *secret*)",
      "Bash(cat *password*)",
      "Bash(echo $*KEY*)",
      "Bash(echo $*SECRET*)",
      "Bash(echo $*PASSWORD*)",
      "Bash(echo $*DATABASE*)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(grep -r KEY .env*)",
      "Bash(grep -r SECRET .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)"
    ]
  }
}